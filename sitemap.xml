---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% assign sitemap_pages = site.html_pages | where_exp: "item", "item.lastmod != nil" | sort: "sitemap_priority" | reverse %}
{% for page in sitemap_pages %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
    <lastmod>{{ page.lastmod }}</lastmod>
    <changefreq>{{ page.sitemap_changefreq | default: "monthly" }}</changefreq>
    <priority>{{ page.sitemap_priority | default: 0.5 }}</priority>
  </url>
{% endfor %}
</urlset>
